# .editorconfig

root = true

# ตั้งค่าสำหรับไฟล์ทุกประเภท
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# ตั้งค่าเฉพาะสำหรับไฟล์ Python
[*.py]
indent_style = space
indent_size = 2

# ตั้งค่าสำหรับไฟล์ JSON (เผื่อคุณใช้สำหรับ Config อื่นๆ)
[*.json]
indent_style = space
indent_size = 2

# ตั้งค่าสำหรับไฟล์ Markdown
[*.md]
indent_style = space
indent_size = 2